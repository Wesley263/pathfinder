# Pathfinder 2.0 本地环境变量示例
#
# 推荐做法：
# 1. 复制本文件为 .env
# 2. 只在 .env 中填写真实密钥，不要提交到 Git
# 3. 默认对齐旧 1.0 本地基础设施：
#    PostgreSQL: localhost:5433 / flightpathfinder / postgres / postgres
#    Redis:      localhost:6380 / password=123456
#    Bootstrap:  localhost:8080
#    MCP Server: localhost:8081

# =========================
# 基础设施（推荐使用 PATHFINDER_ 前缀）
# =========================
PATHFINDER_DB_URL=jdbc:postgresql://localhost:5433/flightpathfinder
PATHFINDER_DB_USERNAME=postgres
PATHFINDER_DB_PASSWORD=postgres
PATHFINDER_REDIS_URL=redis://:123456@localhost:6380

# 服务端口
SERVER_PORT=8080
PATHFINDER_MCP_SERVER_PORT=8081
PATHFINDER_MCP_SERVER_URL=http://localhost:8081

# =========================
# AI Provider 配置
# provider 是“上游模型服务商/接入点”这一层
# chat / embedding 是“能力分工”这一层
# 当前默认：chat -> siliconflow, embedding -> bailian
# =========================

# Chat（当前用于 final answer / rewrite / intent classify / MCP 参数提取 / summary）
PATHFINDER_CHAT_PROVIDER=siliconflow
PATHFINDER_CHAT_MODEL=Qwen/Qwen2.5-72B-Instruct
PATHFINDER_CHAT_TIMEOUT_MS=30000
PATHFINDER_CHAT_TEMPERATURE=0.2
PATHFINDER_CHAT_MAX_TOKENS=4096

# SiliconFlow provider
PATHFINDER_SILICONFLOW_BASE_URL=https://api.siliconflow.cn
PATHFINDER_SILICONFLOW_API_KEY=

# Embedding（当前用于 KB 检索）
PATHFINDER_EMBEDDING_PROVIDER=bailian
PATHFINDER_EMBEDDING_MODEL=text-embedding-v3
PATHFINDER_EMBEDDING_TIMEOUT_MS=30000
PATHFINDER_EMBEDDING_DIMENSION=1024

# Bailian provider
PATHFINDER_BAILIAN_BASE_URL=https://dashscope.aliyuncs.com
PATHFINDER_BAILIAN_API_KEY=

# =========================
# 可选覆盖项
# 仅在 bootstrap / mcp-server 需要使用不同连接时再单独填写
# =========================
# PATHFINDER_MCP_DB_URL=jdbc:postgresql://localhost:5433/flightpathfinder
# PATHFINDER_MCP_DB_USERNAME=postgres
# PATHFINDER_MCP_DB_PASSWORD=postgres

# =========================
# 兼容旧命名（非推荐，仅为平滑过渡保留）
# 如果你已有旧环境变量，也可以暂时继续使用这些名称
# =========================
# DATABASE_URL=jdbc:postgresql://localhost:5433/flightpathfinder
# DATABASE_USERNAME=postgres
# DATABASE_PASSWORD=postgres
# REDIS_URL=redis://:123456@localhost:6380